<%- include("partials/header") %>
<%- include("partials/nav") %>

<main class="page-container">
  <h1>My Account</h1>

  <% if (error) { %>
    <p class="form-message error-message"><%= error %></p>
  <% } %>

  <% if (success) { %>
    <p class="form-message success-message"><%= success %></p>
  <% } %>

  <section class="account-layout">
    <form action="/account" method="POST" class="form-card">
      <h2>Account Details</h2>

      <label for="username">Username</label>
      <input
        type="text"
        id="username"
        name="username"
        value="<%= user.username %>"
        required
      >

      <label for="email">Email</label>
      <input
        type="email"
        id="email"
        name="email"
        value="<%= user.email %>"
        required
      >

      <hr class="form-divider">

      <h2>Change Password</h2>
      <p class="form-help">Leave these blank if you do not want to change your password.</p>

      <label for="currentPassword">Current Password</label>
      <input
        type="password"
        id="currentPassword"
        name="currentPassword"
      >

      <label for="newPassword">New Password</label>
      <input
        type="password"
        id="newPassword"
        name="newPassword"
      >

      <button type="submit">Save Changes</button>
    </form>

    <form action="/account/delete" method="POST" class="form-card danger-card">
      <h2>Delete Account</h2>

      <p>
        This will permanently delete your account. Type your email to confirm:
      </p>

      <p class="delete-email"><%= user.email %></p>

      <label for="confirmDelete">Confirm Email</label>
      <input
        type="text"
        id="confirmDelete"
        name="confirmDelete"
        required
      >

      <button type="submit" class="danger-button">Delete Account</button>
    </form>
  </section>
</main>

<%- include("partials/footer") %>