<%- include("../partials/header") %>
<%- include("../partials/nav") %>

<main class="content-page">
  <section class="page-header">
    <p class="eyebrow">Rules Compendium</p>
    <h1>Cultures</h1>
    <p>
      Browse the peoples and ancestral lineages of Kalix.
    </p>
  </section>

  <section class="card-grid">
    <% cultures.forEach((culture) => { %>
      <article class="content-card">
        <h2><%= culture.name %></h2>
        <p><%= culture.summary %></p>
        <a href="/cultures/<%= culture.slug %>">View Culture</a>
      </article>
    <% }) %>
  </section>
</main>

<%- include("../partials/footer") %>