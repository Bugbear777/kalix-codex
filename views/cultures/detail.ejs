<%- include("../partials/header") %>
<%- include("../partials/nav") %>

<main class="content-page">
  <section class="page-header">
    <p class="eyebrow">Culture</p>
    <h1><%= culture.name %></h1>
    <p><%= culture.summary %></p>
  </section>

  <section class="detail-panel">
    <h2>Overview</h2>
    <p><%= culture.description %></p>

    <h2>Traits</h2>
    <ul class="trait-list">
      <% culture.traits.forEach((trait) => { %>
        <li><%= trait %></li>
      <% }) %>
    </ul>

    <a class="button secondary" href="/cultures">Back to Cultures</a>
  </section>
</main>

<%- include("../partials/footer") %>